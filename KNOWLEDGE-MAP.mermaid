graph TB
    subgraph "🧠 Knowledge System"
        HUB[knowledge-hub<br/>Central Index]
        
        subgraph "📚 Content Repos"
            PRES[markdown-presentations<br/>Marp · Purple Theme]
            RN[research-notes<br/>Zettelkasten]
            CURR[med-ed-curriculum<br/>Course Design]
            AI[ai-prompts-workflows<br/>Prompt Library]
        end
        
        subgraph "📄 Personal Repos"
            CV[curriculum-vitae<br/>Branched CV]
            JOURNEY[ai-journey<br/>Milestones]
        end
    end
    
    subgraph "🌐 Separate"
        ILAI[ilai.academy<br/>Website]
    end
    
    HUB --> PRES
    HUB --> RN
    HUB --> CURR
    HUB --> AI
    HUB --> CV
    HUB --> JOURNEY
    
    RN -.->|insights| PRES
    RN -.->|evidence| CURR
    AI -.->|enhances| CURR
    AI -.->|powers| PRES
    JOURNEY -.->|milestones| HUB
